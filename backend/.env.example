# Copy to .env and fill in.

# --- OpenRouter (free models) — the only key needed ---
# OpenRouter is OpenAI-compatible. It powers the interviewer + scoring.
# Speech-to-text and text-to-speech run in the browser (free, no key).
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- Free models, tried in order (fallback chain) ---
# Free models are shared and often rate-limited (HTTP 429). The provider walks
# this comma-separated list until one answers. Add/reorder as availability shifts.
LLM_MODELS=openai/gpt-oss-20b:free,nvidia/nemotron-3-super-120b-a12b:free,meta-llama/llama-3.3-70b-instruct:free

# --- Google Sign-In (login required when set) ---
# Create an OAuth 2.0 Web client at console.cloud.google.com:
#   APIs & Services → Credentials → Create Credentials → OAuth client ID
#   Application type: Web application
#   Authorized JavaScript origins: http://localhost:8000
# Paste the client ID here. Leave empty to run without login (dev only).
GOOGLE_CLIENT_ID=
# Secret that signs DuSu session tokens — use a long random string in production.
SESSION_SECRET=change-me-to-a-long-random-string

# --- Server ---
HOST=0.0.0.0
PORT=8000
